# Copy to .env.local. Supabase project credentials (Phase 3 auth).
# Find these in the Supabase dashboard -> Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Backend API origin. Next proxies /api/* to this server-side (see next.config.js).
# Server-only var (no NEXT_PUBLIC_ prefix). Defaults to local dev if unset.
# In prod set this to your deployed API, e.g. https://focusforge-api.fly.dev
API_URL=http://localhost:8000
