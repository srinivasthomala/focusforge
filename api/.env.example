# Copy to .env and adjust. Used by the FastAPI app (see app/config.py).
# Default matches docker-compose.yml in this directory.

DATABASE_URL=postgresql+psycopg2://focusforge:focusforge@localhost:5432/focusforge

# You can also use a plain postgres URL; the API normalizes it for SQLAlchemy:
# DATABASE_URL=postgresql://focusforge:focusforge@localhost:5432/focusforge

# Optional: enables real AI summaries via Anthropic Claude. Leave unset and the
# API serves a deterministic fallback so the app still works without a key.
# Keep your real key in api/.env (gitignored) — never commit it here.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# Abuse guards for a public demo (only real Claude calls count against these):
# AI_DAILY_GENERATION_LIMIT=50
# AI_RATE_LIMIT_PER_IP=5
# AI_RATE_LIMIT_WINDOW_SECONDS=3600
